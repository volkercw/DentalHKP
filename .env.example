# Kopiere diese Datei nach .env und trage deine Werte ein:
#   cp .env.example .env

# Anthropic API Key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-...dein-key-hier...

# Claude-Modell
CLAUDE_MODEL=claude-sonnet-4-6

# Datenbank (Charly Solutio – PostgreSQL)
DB_HOST=192.168.x.x
DB_PORT=5432
DB_NAME=solutiodb
DB_USER=postgres
DB_PASSWORD=dein-passwort-hier

# Projektordner (im Docker wird dieser Pfad gemappt)
# Windows-Beispiel: D:\DentalProjekte
# Docker-intern:   /app/projekte
PROJEKTE_PFAD=/app/projekte

# Stücklisten-Katalog aktivieren (true/false)
USE_KATALOG=true
